# Supabase Configuration
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# Public Supabase URL — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable (anon) key — safe to expose to the browser, RLS enforced
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — SERVER ONLY, bypasses RLS
# NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Application base URL
NEXT_PUBLIC_APP_URL=

#Resend Email
RESEND_API_KEY=
EMAIL_FROM=

# Playwright E2E Test Accounts
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_EMPLOYEE_EMAIL=
E2E_EMPLOYEE_PASSWORD=
E2E_MANAGER_EMAIL=
E2E_MANAGER_PASSWORD=
E2E_UNRELATED_EMAIL=
E2E_UNRELATED_PASSWORD=